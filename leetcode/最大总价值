class Solution {
public:
    int MOD = 1e9 + 7;

    long count(vector<int>& value, vector<int>& decay, int mid) {
        int n = value.size();
        long res = 0;
        for (int i = 0; i < n; i++) {
            if (value[i] < mid)
                continue;
            res += (value[i] - mid) / decay[i] + 1;
        }

        return res;
    }

    long long sum(vector<int>& value, vector<int>& decay, long mid) {
        int n = value.size();
        long long res = 0;
        bool p = false;
        for (int i = 0; i < n; i++) {
            if (value[i] < mid)
                continue;
            long long k = (value[i] - mid) / decay[i] + 1;
            long long tal = value[i] - (k - 1) * decay[i];
            long long tmp = (((long long)value[i] + tal) * k / 2);
            res = (res + tmp) % MOD;
        }

        return res;
    }

    int maxTotalValue(vector<int>& value, vector<int>& decay, int m) {
        long r = 0, l = 0;
        for(long num : value) {
            r = max(r, num);
        }
        
        long t = l;
        while (r >= l) {
            long mid = (r + l) / 2;
            int cnt = count(value, decay, mid);
            if (cnt >= m) {
                t = mid;
                l = mid + 1;
            } else {
                r = mid - 1;
            }
        }

        long num = count(value, decay, t);

        long long res = sum(value, decay, t);

        if (num > m) 
        res = (res - (((long long)num - (long long)m) % MOD)* (t % MOD) % MOD + MOD) % MOD;;


        return res;
    }
};
